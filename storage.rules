rules_version = '2';

// Cloud Storage rules for the NAΦ Portal. Paste this into Firebase Console ->
// Storage -> Rules -> Publish (same manual-publish flow as /firestore.rules —
// this file being committed here does not take effect on its own). Storage
// requires the project to be on the Blaze (pay-as-you-go) plan; it won't
// initialize on the free Spark plan.
service firebase.storage {
  match /b/{bucket}/o {
    // Pledge class photos & videos: any signed-in brother can upload; every
    // brother can view. Deleting an object is only allowed for whoever
    // uploaded it (recorded as custom metadata at upload time) or an admin
    // (checked against their Firestore user doc, mirroring firestore.rules'
    // isAdmin()).
    match /pledgeClassMedia/{classId}/{fileName} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.size < 100 * 1024 * 1024
        && request.resource.contentType.matches('image/.*|video/.*');

      allow delete: if request.auth != null
        && (resource.metadata.uploaderUid == request.auth.uid
          || firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin == true);
    }
  }
}
