rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // Brother profiles: any signed-in brother can read (needed to show names on
    // announcements/events/comments), only the owner can create/update their own doc.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.auth.uid == uid;
      allow delete: if false;
    }

    match /announcements/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorUid == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.authorUid == request.auth.uid;

      // Delete is also allowed for the announcement's own author, not just the
      // comment's — deleting an announcement cascades to delete every comment
      // underneath it (see deleteAnnouncementCascade), including ones the
      // announcement author didn't write themselves.
      match /comments/{cid} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.authorUid == request.auth.uid;
        allow update: if isSignedIn() && resource.data.authorUid == request.auth.uid;
        allow delete: if isSignedIn() && (
          resource.data.authorUid == request.auth.uid ||
          get(/databases/$(database)/documents/announcements/$(id)).data.authorUid == request.auth.uid
        );
      }
    }

    match /events/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.createdByUid == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.createdByUid == request.auth.uid;

      // RSVP doc ID must equal the writer's own uid for create/update — you can
      // only ever set your own RSVP. Delete is also allowed for the event's
      // owner, since deleting an event cascades to delete every RSVP under it
      // (see deleteEventCascade), including brothers' RSVPs other than their own.
      match /rsvps/{rsvpUid} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn() && request.auth.uid == rsvpUid;
        allow delete: if isSignedIn() && (
          request.auth.uid == rsvpUid ||
          get(/databases/$(database)/documents/events/$(id)).data.createdByUid == request.auth.uid
        );
      }

      // Same cascade-delete reasoning as announcements/{id}/comments above.
      match /comments/{cid} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.authorUid == request.auth.uid;
        allow update: if isSignedIn() && resource.data.authorUid == request.auth.uid;
        allow delete: if isSignedIn() && (
          resource.data.authorUid == request.auth.uid ||
          get(/databases/$(database)/documents/events/$(id)).data.createdByUid == request.auth.uid
        );
      }
    }

    // Comment notifications: the commenter (actor) creates the doc for the
    // post owner (recipient). Only the recipient can read their own
    // notifications, and their only allowed write is flipping `read`.
    match /notifications/{id} {
      allow read: if isSignedIn() && resource.data.recipientUid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.actorUid == request.auth.uid;
      allow update: if isSignedIn() && resource.data.recipientUid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isSignedIn() && resource.data.recipientUid == request.auth.uid;
    }

    // Forms (Google-Forms-style): the owner (createdByUid) can fully manage
    // the form, including who's listed in collaboratorUids. A form doc can
    // also be read by anyone, signed in or not, once published == true — that
    // public GET is what powers the public "fill out this form" link. List
    // queries (the portal's "My Forms" / "Shared with Me") still require
    // sign-in and are scoped per-document to owner/collaborator by the same
    // rule, same pattern as /notifications above.
    match /forms/{formId} {
      // resource == null first: a GET on a form id that doesn't exist (bad/typo'd
      // public link) has nothing to protect, and must short-circuit to true
      // before the other clauses touch resource.data — otherwise accessing
      // .data on a null resource throws and the whole rule denies, which
      // surfaces to visitors as a permission error instead of "not found".
      allow read: if resource == null
        || resource.data.published == true
        || (isSignedIn() && (
          resource.data.createdByUid == request.auth.uid ||
          (resource.data.collaboratorUids is list && request.auth.uid in resource.data.collaboratorUids)
        ));
      allow create: if isSignedIn() && request.resource.data.createdByUid == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.createdByUid == request.auth.uid;

      // Responses: anyone (including unauthenticated visitors via the public
      // link) can submit a response while the form is published, unless the
      // owner turned on requireSignIn — then only a signed-in brother can.
      // Only the form's owner or collaborators can read the responses back.
      match /responses/{responseId} {
        allow create: if get(/databases/$(database)/documents/forms/$(formId)).data.published == true
          && (get(/databases/$(database)/documents/forms/$(formId)).data.requireSignIn != true || isSignedIn());
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/forms/$(formId)).data.createdByUid == request.auth.uid ||
          (get(/databases/$(database)/documents/forms/$(formId)).data.collaboratorUids is list &&
            request.auth.uid in get(/databases/$(database)/documents/forms/$(formId)).data.collaboratorUids)
        );
        allow update: if false;
        // Delete is only for the form's owner, mirroring who can delete the form
        // itself — needed so deleteFormCascade can clear out responses when a
        // form (which may have responses from other brothers) gets deleted.
        allow delete: if isSignedIn() && get(/databases/$(database)/documents/forms/$(formId)).data.createdByUid == request.auth.uid;
      }
    }
  }
}
